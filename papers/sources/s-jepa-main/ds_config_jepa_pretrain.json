{
  "train_micro_batch_size_per_gpu": 128,
  "gradient_accumulation_steps": 1,
  "gradient_clipping": 1.0,
  "steps_per_print": 100,
  "wall_clock_breakdown": false,

  "bf16": {
    "enabled": true
  },

  "zero_optimization": {
    "stage": 1,
    "overlap_comm": true,
    "contiguous_gradients": true
  },

  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "warmup_min_lr": 1e-5,
      "warmup_max_lr": 2.5e-4,
      "warmup_num_steps": 5000,
      "total_num_steps": 50000,
      "warmup_type": "linear"
    }
  }
}
